{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":prHourlyLimit2",
    ":prConcurrentLimit10",
    "group:allNonMajor"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "Asia/Tokyo",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchPackageNames": ["@biomejs/biome", "typescript", "vitest"],
      "groupName": "linters and tooling"
    },
    {
      "matchPackageNames": [
        "react",
        "react-native",
        "react-native-reanimated",
        "react-native-pager-view",
        "react-native-worklets",
        "expo"
      ],
      "groupName": "react native core",
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "pinDigests": true
    }
  ],
  "prConcurrentLimit": 5,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  }
}
